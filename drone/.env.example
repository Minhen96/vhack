# ── Drone identity ────────────────────────────────────────────────────────────
# Leave DRONE_ID blank to auto-generate from type + port + random suffix (recommended).
DRONE_ID=
DRONE_TYPE=scanner         # scanner | delivery
DRONE_HOST=localhost
DRONE_PORT=8001

# ── Teammate service URLs ──────────────────────────────────────────────────────
MCP_URL=http://localhost:9000
MAP_WS_URL=ws://localhost:9001/ws/drone