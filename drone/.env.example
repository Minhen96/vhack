# =============================================================================
# Drone process — example configuration
# Copy to drone/.env and fill in values.
# For a second drone, run a separate process with DRONE_PORT=8002.
# =============================================================================

# ── Drone identity ────────────────────────────────────────────────────────────
# Leave blank to auto-generate: <type>_<port>_<random4>  e.g. scanner_8001_a3f2
DRONE_ID=

# scanner  — has thermal camera, no payload
# delivery — carries aid supplies, no thermal camera
DRONE_TYPE=scanner

# Host/port this drone's own FastAPI server listens on.
# The backend MCP server proxies commands to http://DRONE_HOST:DRONE_PORT
DRONE_HOST=localhost
DRONE_PORT=8001

# ── Service URLs ──────────────────────────────────────────────────────────────
# Backend FastAPI base URL — drone POSTs to /register and /deregister here
MCP_URL=http://localhost:8000

# Go Sim Server HTTP URL — drone calls GET /scan here for thermal data
SIM_SERVER_URL=http://localhost:8080

# Go Sim Server WebSocket URL — drone connects here to receive obstacle grid updates
MAP_WS_URL=ws://localhost:8080/ws/drone