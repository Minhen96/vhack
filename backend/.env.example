# =============================================================================
# Backend / LLM Agent — example configuration
# Copy to backend/.env and fill in your API key.
# =============================================================================

# Which LLM to use: deepseek | gemini | openai | anthropic
LLM_PROVIDER=deepseek

# API keys — fill in the one matching LLM_PROVIDER
DEEPSEEK_API_KEY=your_deepseek_key_here
# GOOGLE_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional model overrides (defaults shown)
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Full Streamable-HTTP URL the Command Agent connects to
# Must match backend FastAPI port (default 8000) and mount path (/mcp/mcp)
MCP_URL=http://localhost:8000/mcp/mcp

# Disaster zone grid size — must match GRID_SIZE env var on the Go sim server
GRID_SIZE=80