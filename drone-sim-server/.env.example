# =============================================================================
# Go Sim Server / Map Engine — example configuration
# Copy to drone-sim-server/.env and adjust as needed.
#
# Go does NOT auto-load .env files. Source this file before running:
#   source .env && go run . --server
# Or pass inline:
#   PORT=8080 go run . --server
# =============================================================================

# HTTP port for the WebSocket hub (/ws/drone, /ws/ui) and /scan HTTP endpoint
# Must match SIM_SERVER_URL and MAP_WS_URL in drone/.env
# Must match VITE_WS_URL in frontend/.env
PORT=8080

# WebSocket URL this process connects to when run in --drone (mock client) mode
# Must match ws://localhost:PORT/ws/drone above
MAP_WS_URL=ws://localhost:8080/ws/drone